# Copy to .env.test (gitignored) for pytest. Loaded by api/conftest.py before api.constants.
#
# DATABASE_URL — base name only; default pytest layout creates {dbname}_test via CREATE DATABASE.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/openvoice_agent
REDIS_URL=redis://127.0.0.1:6379/0
LOG_LEVEL=WARNING

# Optional: asyncpg URL to an existing Postgres database used only for pytest.
# When set, conftest skips CREATE DATABASE (no CREATEDB privilege needed).
# Create the DB once, e.g.: createdb -h 127.0.0.1 -U postgres openvoice_agent_test
# PYTEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/openvoice_agent_test
