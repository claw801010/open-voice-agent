BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_NODE_ENV=development
# Optional — Playwright authenticated specs (MK-01 Analytics E2E); see ui/AGENTS.md
# E2E_EMAIL=e2e-operator@example.com
# E2E_PASSWORD=your-secret
# E2E_BACKEND_URL=http://127.0.0.1:8000
# E2E_BASE_URL=http://127.0.0.1:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1
# Stack-backed UI (middleware does not OSS-gate): skip OSS login redirect spec; optional Stack smoke without cookies.
# E2E_EXPECT_STACK_AUTH=1
# With authenticated specs — either save cookies once (`npx playwright codegen ...` → storage) or impersonate:
# E2E_PLAYWRIGHT_STORAGE_STATE=./e2e/.auth/stack-user.json
# E2E_STACK_REFRESH_TOKEN=...   # staging-only; `/impersonate?refresh_token=…`
# E2E_STRICT_REDACTION_RBAC=1
# E2E_EXPECT_SUPERUSER_MAY_DISABLE=1
# Optional (WE-01-HEADER / WE-01-FEEDBACK): extra "Open external form" link inside the in-app feedback dialog — https URL or mailto:
# NEXT_PUBLIC_FEEDBACK_URL=https://github.com/org/repo/issues/new
